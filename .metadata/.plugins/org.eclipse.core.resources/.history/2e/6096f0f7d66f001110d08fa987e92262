/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{
  /* USER CODE BEGIN 1 */
  System_Init();
  /* USER CODE END 1 */
  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
    // Manage the temperature and reference voltage
    Manage_temp_vref();

    // Manage the IMU and update the sensor output data

    Manage_IMU();
    
    // Manage all outputs based on the current EEPROM configuration
    Manage_Outputs();

    HAL_IWDG_Refresh(&hiwdg);
    // Output the sensor data to the serial console
    //Serial_Out();

  }
}

/**
  * @brief Manage outputs based on EEPROM configuration
  * This function manages the outputs based on the configuration stored in EEPROM.
  * It updates the DAC outputs, CANopen stack, and LED indicators accordingly.
  * @param EE_conf: The EEPROM configuration structure containing output settings.
  */
void Manage_Outputs(void)
{
  Manage_CAN();
  Manage_DAC();
  Manage_LED_Green();
  //HAL_IWDG_Refresh(&hiwdg);
}
void System_Init(void)
{
  HAL_Init();
  SystemClock_Config();
  //Load_Error_Log_From_Flash();// Load error log from flash memory
  EEPROM_Init();
  MX_GPIO_Init();
  MX_DMA_Init();
  MX_ADC1_Init();
  MX_FDCAN1_Init();
  if(EEPROM_CONFIG_BACKUP.OUT_TYPE == CAN)
  {
    HAL_DAC_DeInit(&hdac1);
  }
  else
  {
    MX_DAC1_Init();
    DAC_Init_Param();
  }
  MX_IWDG_Init();
  MX_TIM2_Init();
  MX_TIM3_Init();
  MX_TIM17_Init();
  MX_LPUART1_UART_Init();
  MX_CRC_Init();
  HAL_TIM_Base_Start(&htim3);
  HAL_ADC_Start_DMA(&hadc1, (uint32_t*)adc_buffer, ADC_BUFFER_LENGTH);
  Init_IMU();
  LED_All_Off();
  CANopen_Init();
}
