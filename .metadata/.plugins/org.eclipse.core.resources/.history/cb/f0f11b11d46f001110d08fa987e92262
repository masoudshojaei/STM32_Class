// Initialize EEPROM configuration with default values if uninitialized or in debug mode
void EEPROM_Init(void)
{
	EEPROM_Read_Default_Config();
	EEPROM_Read_Config_New();
	EEPROM_Set_Default();
	if (EEPROM_CONFIG_DEFAULT.EEPROM_STATUS_ID != NEW_CONFIG_WRITTEN)
	{
		EEPROM_Write_Config_Default();
	}
   // Check if the new config is valid (non-zero and different from default)
    if (EEPROM_CONFIG_NEW.EEPROM_STATUS_ID == NEW_CONFIG_WRITTEN ||
    	EEPROM_CONFIG_NEW.RAM_STATUS_BAUDRATE == NEW_CONFIG_WRITTEN )
    {
        // New config is valid -> use it
        EEPROM_New_To_Backup();
        EEPROM_CONFIG_NEW.RAM_STATUS_ID = 0;
        EEPROM_CONFIG_NEW.RAM_STATUS_BAUDRATE = 0;
    }
    else if (EEPROM_CONFIG_NEW.EEPROM_STATUS_ID == SET_BACK_TO_DEFAULT )
    {
    	// using default config
    	EEPROM_Set_New_Empty();
    	EEPROM_Default_To_Backup();
    }
    else
    {
    	// using default config
    	EEPROM_Default_To_Backup();

    }


    // Otherwise, keep default config in EEPROM_CONFIG*/

}
void EEPROM_Check_For_Config_New(void)
{
    if ((canopenNodeSTM32->canOpenStack->LSSslave->service == CO_LSS_CFG_STORE)&&
    		(canopenNodeSTM32->activeNodeID != canopenNodeSTM32->desiredNodeID)&&
			(EEPROM_CONFIG_NEW.RAM_STATUS_ID != NEW_CONFIG_WRITTEN))
    {
    	EEPROM_CONFIG_NEW.CAN_ID 			= canopenNodeSTM32->desiredNodeID;
    	EEPROM_CONFIG_NEW.RAM_STATUS_ID 	= NEW_CONFIG_WRITTEN;
    	EEPROM_CONFIG_NEW.EEPROM_STATUS_ID 	= NEW_CONFIG_WRITTEN;

		EEPROM_CONFIG_NEW.CAN_BAUDRATE 				= EEPROM_CONFIG_BACKUP.CAN_BAUDRATE;
		EEPROM_CONFIG_NEW.RAM_STATUS_BAUDRATE 		= EEPROM_CONFIG_BACKUP.RAM_STATUS_BAUDRATE;
		EEPROM_CONFIG_NEW.EEPROM_STATUS_BAUDRATE 	= EEPROM_CONFIG_BACKUP.EEPROM_STATUS_BAUDRATE;

		EEPROM_CONFIG_NEW.SOFTWARE_VERSION 			= EEPROM_CONFIG_BACKUP.SOFTWARE_VERSION;
		EEPROM_CONFIG_NEW.OUT_TYPE 					= EEPROM_CONFIG_BACKUP.OUT_TYPE;
		EEPROM_CONFIG_NEW.ANGULAR_RANGE 			= EEPROM_CONFIG_BACKUP.ANGULAR_RANGE;
		EEPROM_CONFIG_NEW.IMU_MODE 					= EEPROM_CONFIG_BACKUP.IMU_MODE;

    	EEPROM_Write_Config_New();
    }
    else if ((canopenNodeSTM32->canOpenStack->LSSslave->service == CO_LSS_CFG_BIT_TIMING)&&
    		(canopenNodeSTM32->canOpenStack->LSSslave->TXbuff->data[1] == 0)&&
    		(EEPROM_CONFIG_NEW.RAM_STATUS_BAUDRATE != NEW_CONFIG_WRITTEN))
    {
    	EEPROM_CONFIG_NEW.CAN_BAUDRATE 				= canopenNodeSTM32->baudrate;
    	EEPROM_CONFIG_NEW.RAM_STATUS_BAUDRATE 		= NEW_CONFIG_WRITTEN;
    	EEPROM_CONFIG_NEW.EEPROM_STATUS_BAUDRATE 	= NEW_CONFIG_WRITTEN;

		EEPROM_CONFIG_NEW.CAN_ID 			= EEPROM_CONFIG_BACKUP.CAN_ID;
		EEPROM_CONFIG_NEW.RAM_STATUS_ID 	= EEPROM_CONFIG_BACKUP.RAM_STATUS_ID;
		EEPROM_CONFIG_NEW.EEPROM_STATUS_ID 	= EEPROM_CONFIG_BACKUP.EEPROM_STATUS_ID;

		EEPROM_CONFIG_NEW.SOFTWARE_VERSION 	= EEPROM_CONFIG_BACKUP.SOFTWARE_VERSION;
		EEPROM_CONFIG_NEW.OUT_TYPE 			= EEPROM_CONFIG_BACKUP.OUT_TYPE;
		EEPROM_CONFIG_NEW.ANGULAR_RANGE 	= EEPROM_CONFIG_BACKUP.ANGULAR_RANGE;
		EEPROM_CONFIG_NEW.IMU_MODE 			= EEPROM_CONFIG_BACKUP.IMU_MODE;

    	EEPROM_Write_Config_New();
    }
