uint8_t	EEPROM_STATUS = NO_NEW_CONFIG_WRITTEN;
uint8_t flash_write_status = FLASH_FREE;
void EEPROM_Read_Default_Config(void)
{
	// Flash base address where the config is stored
	const uint32_t *flashPtr = (const uint32_t *)EEPROM_PAGE_ADDRESS_CONFIG;

	// Destination RAM struct
	uint32_t *ramPtr = (uint32_t *)&EEPROM_CONFIG_DEFAULT;

	// Copy the struct double-word by double-word
	for (uint32_t i = 0; i < sizeof(EEPROM_Config_t) / sizeof(uint32_t); i++)
	{
		ramPtr[i] = flashPtr[i];
	}

}

