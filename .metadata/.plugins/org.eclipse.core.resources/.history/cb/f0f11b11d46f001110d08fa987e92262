// Write the default configuration
__attribute__((section(".RamFunc")))
void EEPROM_Write_Config_Default(void)
{
    HAL_FLASH_Unlock();

    // Erase the page
    FLASH_EraseInitTypeDef eraseInit;
    uint32_t pageError, erase_error_code,write_error_code;

    eraseInit.TypeErase   = FLASH_TYPEERASE_PAGES;
    eraseInit.Banks       = FLASH_BANK_1;
    eraseInit.Page        = EEPROM_PAGE_NUMBER_CONFIG; // Last page for 512KB
    eraseInit.NbPages     = 1;
    erase_error_code = HAL_FLASHEx_Erase(&eraseInit, &pageError);
    if (erase_error_code != HAL_OK) {
        HAL_FLASH_Lock();
        return;
    }
	// Program double words (64-bit)
    const uint64_t *src = (const uint64_t *)&EEPROM_CONFIG;
    for (uint32_t i = 0; i < sizeof(EEPROM_Config_t) / sizeof(uint64_t); i++)
    {
    	write_error_code = HAL_FLASH_Program(FLASH_TYPEPROGRAM_DOUBLEWORD, EEPROM_PAGE_ADDRESS_CONFIG + (i * 8), src[i]);
        if (write_error_code != HAL_OK)
        {
            // Optional: handle error (e.g., break, log)
        	HAL_FLASH_Lock();
            break;
        }
    }

    HAL_FLASH_Lock();
}


