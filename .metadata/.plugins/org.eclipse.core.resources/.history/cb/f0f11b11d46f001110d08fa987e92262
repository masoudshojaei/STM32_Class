__attribute__((section(".RamFunc"), noinline, used))
void EEPROM_Write_Config_New(void)
{
    const uint64_t *src = (const uint64_t *)&EEPROM_CONFIG_NEW;
    uint32_t addr = EEPROM_PAGE_ADDRESS_CONFIG_NEW;

    // STM32G4 specifics
    uint32_t page_number = EEPROM_PAGE_NUMBER_CONFIG_NEW;
    uint32_t count = (sizeof(EEPROM_Config_t) + 7) / 8;   // number of 64-bit writes

    // ----------------------------------------------------------
    // UNLOCK FLASH (register-level)
    // ----------------------------------------------------------
    if (FLASH->CR & FLASH_CR_LOCK) {
        FLASH->KEYR = FLASH_KEY1;
        FLASH->KEYR = FLASH_KEY2;
    }

    // ----------------------------------------------------------
    // ERASE PAGE
    // ----------------------------------------------------------
    // Clear all previous flash status flags
    FLASH->SR |= FLASH_SR_PROGERR | FLASH_SR_PGAERR | FLASH_SR_PGSERR |
                 FLASH_SR_WRPERR | FLASH_SR_EOP;

    // Enable page erase mode
    FLASH->CR |= FLASH_CR_PER;

    // Set page number (12-bit PNB)
    FLASH->CR &= ~FLASH_CR_PNB;
    FLASH->CR |= (page_number << FLASH_CR_PNB_Pos);

    // Start erase
    FLASH->CR |= FLASH_CR_STRT;

    // Wait for erase to complete
    while (FLASH->SR & FLASH_SR_BSY) { /* feed WDG if needed */ }

    // Exit erase mode
    FLASH->CR &= ~FLASH_CR_PER;

    // Check erase errors
    if (FLASH->SR & (FLASH_SR_WRPERR | FLASH_SR_PGAERR |
                     FLASH_SR_PROGERR | FLASH_SR_PGSERR)) {

        FLASH->SR |= FLASH_SR_PROGERR | FLASH_SR_PGAERR | FLASH_SR_PGSERR |
                     FLASH_SR_WRPERR | FLASH_SR_EOP;

        FLASH->CR |= FLASH_CR_LOCK;
        return;
    }

    // ----------------------------------------------------------
    // PROGRAM DOUBLE-WORDS (64-bit)
    // ----------------------------------------------------------
    for (uint32_t i = 0; i < count; i++)
    {
        // Clear old flags
        FLASH->SR |= FLASH_SR_PROGERR | FLASH_SR_PGAERR | FLASH_SR_PGSERR |
                     FLASH_SR_WRPERR | FLASH_SR_EOP;

        // Enable programming mode
        FLASH->CR |= FLASH_CR_PG;

        // Destination address must be 64-bit aligned
        uint64_t *dest = (uint64_t *)(addr + (i * 8));

        // Write actual 64-bit data
        *dest = src[i];

        // Wait for completion
        while (FLASH->SR & FLASH_SR_BSY) { }

        // Disable PG
        FLASH->CR &= ~FLASH_CR_PG;

        // Check for program errors
        if (FLASH->SR & (FLASH_SR_PROGERR | FLASH_SR_PGAERR |
                         FLASH_SR_PGSERR | FLASH_SR_WRPERR)) {

            FLASH->SR |= FLASH_SR_PROGERR | FLASH_SR_PGAERR |
                         FLASH_SR_PGSERR | FLASH_SR_WRPERR | FLASH_SR_EOP;

            FLASH->CR |= FLASH_CR_LOCK;
            return;
        }
    }

    // ----------------------------------------------------------
    // LOCK FLASH
    // ----------------------------------------------------------
    FLASH->CR |= FLASH_CR_LOCK;
}


uint8_t is_non_zero_config(const EEPROM_Config_t *cfg)
{
    const uint8_t *p = (const uint8_t *)cfg;
    for (size_t i = 0; i < sizeof(EEPROM_Config_t); i++) {
        if (p[i] != 0)
        	return 1; // found a non-zero byte
    }
    return 0;
}

void EEPROM_Set_Default(void)
{
	EEPROM_CONFIG.SOFTWARE_VERSION 			= SOFTWARE_VERSION_VAL;
	EEPROM_CONFIG.OUT_TYPE 					= OUT_TYPE_VAL;
	EEPROM_CONFIG.ANGULAR_RANGE 			= ANGULAR_RANGE_VAL;
	EEPROM_CONFIG.IMU_MODE 					= IMU_MODE_VAL;
	EEPROM_CONFIG.CAN_ID 					= DEFAULT_CAN_ID;
	EEPROM_CONFIG.CAN_BAUDRATE 				= DEFAULT_CAN_BAUDRATE;
	EEPROM_CONFIG.EEPROM_STATUS_ID 			= NEW_CONFIG_WRITTEN;
	EEPROM_CONFIG.EEPROM_STATUS_BAUDRATE	= NEW_CONFIG_WRITTEN;
	EEPROM_CONFIG.RAM_STATUS_ID 			= 0;
	EEPROM_CONFIG.RAM_STATUS_BAUDRATE 		= 0;
}
